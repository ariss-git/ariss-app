generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ariss {
  id            String         @id
  name          String
  email         String         @unique
  profilePicUrl String?
  type          ArissUserType?
  status        Boolean        @default(false)
  createdAt     DateTime       @default(now())
}

model customers {
  id               String        @id
  name             String
  phone            String        @unique
  email            String        @unique
  type             CustomerType?
  gstin            String?
  profilePicUrl    String?
  businessPicUrl   String?
  shippingAddress  Json?
  billingAddress   Json?
  status           Boolean       @default(false)
  profileCompleted Boolean       @default(false)
  createdAt        DateTime      @default(now())

  dealerId String?
  dealer   customers? @relation("CustomerHierarchy", fields: [dealerId], references: [id])

  employees customers[] @relation("CustomerHierarchy")
}

enum ArissUserType {
  SUPER
  ADMIN
  MODERATOR
}

enum CustomerType {
  DEALER
  TECHNICIAN
  BACKOFFICE
}
