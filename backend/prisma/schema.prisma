generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ariss {
  id            String         @id
  name          String
  email         String         @unique
  profilePicUrl String?
  type          ArissUserType?
  status        Boolean        @default(false)
  createdAt     DateTime       @default(now())
}

model customers {
  id               String        @id
  name             String
  phone            String?       @unique
  email            String        @unique
  profilePicUrl    String?
  type             CustomerType?
  gstin            String?
  businessName     String?
  businessPicUrl   String?
  shippingAddress  Json?
  billingAddress   Json?
  status           Boolean       @default(false)
  profileCompleted Boolean       @default(false)
  createdAt        DateTime      @default(now())

  dealerId String?
  dealer   customers? @relation("CustomerHierarchy", fields: [dealerId], references: [id])

  employees customers[] @relation("CustomerHierarchy")
}

model categories {
  id        String   @id @default(uuid())
  name      String   @unique
  imageUrl  String
  filePath  String
  createdAt DateTime @default(now())

  subcategories subcategories[]
}

model subcategories {
  id        String   @id @default(uuid())
  name      String   @unique
  imageUrl  String
  filePath  String
  createdAt DateTime @default(now())

  categoryId String?
  categories categories? @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  products products[]
}

model products {
  id          String   @id @default(uuid())
  name        String
  description Json
  type        String
  label       String
  warranty    Int
  quantity    Int
  sku         String?
  usps        String?
  status      Boolean  @default(false)
  imageUrls   String[]
  filePath    String[]
  createdAt   DateTime @default(now())

  subcategoryId String?
  subcategories subcategories? @relation(fields: [subcategoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

enum ArissUserType {
  SUPER
  ADMIN
  MODERATOR
}

enum CustomerType {
  DEALER
  TECHNICIAN
  BACKOFFICE
}
